# ==================== 邮件发送配置 ====================
# SMTP服务器地址（例如：smtp.163.com, smtp.qq.com, smtp.gmail.com）
SMTP_SERVER=smtp.163.com

# SMTP服务器端口（SSL通常为465，TLS通常为587）
SMTP_PORT=465

# 发件人邮箱地址
SENDER_EMAIL=your_email@example.com

# 邮箱授权码（不是登录密码，需在邮箱设置中开启SMTP服务并获取）
AUTH_CODE=your_auth_code_here

# ==================== 附件配置 ====================
# 附件路径列表（JSON数组格式，支持PDF、图片、Word等）
# 注意：Windows路径中的反斜杠需要转义为双反斜杠，或使用正斜杠
ATTACHMENTS=[
    "D:\\path\\to\\your\\resume.pdf",
    "D:\\path\\to\\your\\transcript.pdf"
]

# ==================== 老师信息提取配置（用于 profList.py）====================
# 存放导师信息的Excel文件路径
EXCEL_FILE=D:\\path\\to\\your\\teacher_list.xlsx

# 提取Excel中的行范围（从1开始计数，包含起始行和结束行）
START_ROW=1
END_ROW=10

# 输出的老师信息文件名（JSON格式）
OUTPUT_FILE=teacher_info.txt